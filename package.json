      "./src/clipboard-image.ts",
      "./src/image-context-pruner.ts",
      "./src/markdown-viewer.ts",
      "./src/screenshot.ts",
      "./src/subagent.ts",
      "./src/context-pruner.ts",
      "./src/daily-log.ts"
